{
  "name": "react-querybuilder-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "website"
  ],
  "scripts": {
    "start": "bun --hot ./utils/devapp/server.ts",
    "start:antd": "bun run --filter @react-querybuilder/antd start",
    "start:bootstrap": "bun run --filter @react-querybuilder/bootstrap start",
    "start:bulma": "bun run --filter @react-querybuilder/bulma start",
    "start:chakra": "bun run --filter @react-querybuilder/chakra start",
    "start:datetime": "bun run --filter @react-querybuilder/datetime start",
    "start:dnd": "bun run --filter @react-querybuilder/dnd start",
    "start:fluent": "bun run --filter @react-querybuilder/fluent start",
    "start:mantine": "bun run --filter @react-querybuilder/mantine start",
    "start:material": "bun run --filter @react-querybuilder/material start",
    "start:native": "bun run --filter @react-querybuilder/native start",
    "start:rqb": "bun run --filter react-querybuilder start",
    "start:re": "bun run --filter @react-querybuilder/rules-engine start",
    "start:prime": "bun run --filter @react-querybuilder/prime start",
    "start:tremor": "bun run --filter @react-querybuilder/tremor start",
    "build": "bun run --filter '{,@}react-querybuilder{,/}*' build",
    "build:concurrent": "concurrently --timings bun:build:core bun:build:rqb bun:build:antd bun:build:bootstrap bun:build:bulma bun:build:chakra bun:build:datetime bun:build:dnd bun:build:fluent bun:build:mantine bun:build:material bun:build:native bun:build:prime bun:build:tremor",
    "build:sequential": "bun --bun run build:core && bun --bun run build:rqb && bun --bun run build:antd && bun --bun run build:bootstrap && bun --bun run build:bulma && bun --bun run build:chakra && bun --bun run build:datetime && bun --bun run build:dnd && bun --bun run build:fluent && bun --bun run build:mantine && bun --bun run build:material && bun --bun run build:native && bun --bun run build:prime && bun --bun run build:tremor",
    "build:antd": "bun --bun run --filter @react-querybuilder/antd build",
    "build:bootstrap": "bun --bun run --filter @react-querybuilder/bootstrap build",
    "build:bulma": "bun --bun run --filter @react-querybuilder/bulma build",
    "build:chakra": "bun --bun run --filter @react-querybuilder/chakra build",
    "build:core": "bun --bun run --filter @react-querybuilder/core build",
    "build:datetime": "bun --bun run --filter @react-querybuilder/datetime build",
    "build:dnd": "bun --bun run --filter @react-querybuilder/dnd build",
    "build:fluent": "bun --bun run --filter @react-querybuilder/fluent build",
    "build:mantine": "bun --bun run --filter @react-querybuilder/mantine build",
    "build:material": "bun --bun run --filter @react-querybuilder/material build",
    "build:native": "bun --bun run --filter @react-querybuilder/native build",
    "build:prime": "bun --bun run --filter @react-querybuilder/prime build",
    "build:rqb": "bun run --filter react-querybuilder build",
    "build:rqb:main": "bun --bun run --filter react-querybuilder build:main",
    "build:rqb:css": "bun run --filter react-querybuilder build:css",
    "build:re": "bun --bun run --filter @react-querybuilder/rules-engine build",
    "build:re:main": "bun --bun run --filter @react-querybuilder/rules-engine build:main",
    "build:re:css": "bun run --filter @react-querybuilder/rules-engine build:css",
    "build:tremor": "bun --bun run --filter @react-querybuilder/tremor build",
    "checkall": "bun install --frozen-lockfile && bun run build && bun run fmt:check && bun run lint && bun run tsnext && bun run test && bun run are-the-types-wrong && bun run website:build",
    "lint": "oxlint",
    "test": "bun test:bun && vitest run --coverage",
    "test:bun": "bun generate-prisma-client; bun test --randomize ./packages/core ./packages/rules-engine/src/**/*.test.ts ./packages/datetime/src/**/*.test.ts # <- Avoids *.test.tsx",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "concurrently --timings --prefix-colors \"#0958d9,#712cf9,#00d1b2,#81e6d9,#663399,cyan,#4078c0,#7fba00,#339af0,#007fff,#61dafb,#06b6d4,#82a7dd,#006633,#60a5fa,darkgray,gray,blue\" --names antd,bootstrap,bulma,chakra,core,datetime,dnd,fluent,mantine,material,native,prime,rqb,re,tremor,utils,examples,website bun:typecheck:antd bun:typecheck:bootstrap bun:typecheck:bulma bun:typecheck:chakra bun:typecheck:core bun:typecheck:datetime bun:typecheck:dnd bun:typecheck:fluent bun:typecheck:mantine bun:typecheck:material bun:typecheck:native bun:typecheck:prime bun:typecheck:rqb bun:typecheck:re bun:typecheck:tremor bun:typecheck:utils bun:typecheck:examples bun:typecheck:website",
    "typecheck:antd": "tsc -p packages/antd",
    "typecheck:bootstrap": "tsc -p packages/bootstrap",
    "typecheck:bulma": "tsc -p packages/bulma",
    "typecheck:chakra": "tsc -p packages/chakra",
    "typecheck:core": "tsc -p packages/core",
    "typecheck:datetime": "tsc -p packages/datetime",
    "typecheck:dnd": "tsc -p packages/dnd",
    "typecheck:fluent": "tsc -p packages/fluent",
    "typecheck:mantine": "tsc -p packages/mantine",
    "typecheck:material": "tsc -p packages/material",
    "typecheck:native": "tsc -p packages/native",
    "typecheck:prime": "tsc -p packages/prime",
    "typecheck:rqb": "tsc -p packages/react-querybuilder",
    "typecheck:re": "tsc -p packages/rules-engine",
    "typecheck:tremor": "tsc -p packages/tremor",
    "typecheck:examples": "tsc -p examples",
    "typecheck:website": "tsc -p website",
    "typecheck:utils": "tsc -p ./tsconfig.json",
    "tsnext": "concurrently --timings --prefix-colors \"#0958d9,#712cf9,#00d1b2,#81e6d9,#663399,cyan,#4078c0,#7fba00,#339af0,#007fff,#61dafb,#06b6d4,#82a7dd,#006633,#60a5fa,darkgray,gray,blue\" --names antd,bootstrap,bulma,chakra,core,datetime,dnd,fluent,mantine,material,native,prime,rqb,re,tremor,utils,examples,website bun:tsnext:antd bun:tsnext:bootstrap bun:tsnext:bulma bun:tsnext:chakra bun:tsnext:core bun:tsnext:datetime bun:tsnext:dnd bun:tsnext:fluent bun:tsnext:mantine bun:tsnext:material bun:tsnext:native bun:tsnext:prime bun:tsnext:rqb bun:tsnext:re bun:tsnext:tremor bun:tsnext:utils bun:tsnext:examples bun:tsnext:website",
    "tsnext:antd": "tsgo -p packages/antd",
    "tsnext:bootstrap": "tsgo -p packages/bootstrap",
    "tsnext:bulma": "tsgo -p packages/bulma",
    "tsnext:chakra": "tsgo -p packages/chakra",
    "tsnext:core": "tsgo -p packages/core",
    "tsnext:datetime": "tsgo -p packages/datetime",
    "tsnext:dnd": "tsgo -p packages/dnd",
    "tsnext:fluent": "tsgo -p packages/fluent",
    "tsnext:mantine": "tsgo -p packages/mantine",
    "tsnext:material": "tsgo -p packages/material",
    "tsnext:native": "tsgo -p packages/native",
    "tsnext:prime": "tsgo -p packages/prime",
    "tsnext:rqb": "tsgo -p packages/react-querybuilder",
    "tsnext:re": "tsgo -p packages/rules-engine",
    "tsnext:tremor": "tsgo -p packages/tremor",
    "tsnext:examples": "tsgo -p examples",
    "tsnext:website": "tsgo -p website",
    "tsnext:utils": "tsgo -p ./tsconfig.json",
    "are-the-types-wrong": "bun run attw:rqb && bun run attw:antd && bun run attw:bootstrap && bun run attw:bulma && bun run attw:chakra && bun run attw:core && bun run attw:datetime && bun run attw:dnd && bun run attw:fluent && bun run attw:mantine && bun run attw:material && bun run attw:native && bun run attw:prime && bun run attw:re && bun run attw:tremor",
    "attw:antd": "attw --format table-flipped --pack ./packages/antd",
    "attw:bootstrap": "attw --format table-flipped --pack ./packages/bootstrap",
    "attw:bulma": "attw --format table-flipped --pack ./packages/bulma",
    "attw:chakra": "attw --format table-flipped --pack ./packages/chakra",
    "attw:core": "attw --format table-flipped --pack ./packages/core",
    "attw:datetime": "attw --format table-flipped --pack ./packages/datetime",
    "attw:dnd": "attw --format table-flipped --pack ./packages/dnd",
    "attw:fluent": "attw --format table-flipped --pack ./packages/fluent",
    "attw:mantine": "attw --format table-flipped --pack ./packages/mantine",
    "attw:material": "attw --format table-flipped --pack ./packages/material",
    "attw:native": "attw --format table-flipped --pack ./packages/native",
    "attw:prime": "attw --format table-flipped --pack ./packages/prime",
    "attw:re": "attw --format table-flipped --pack ./packages/rules-engine",
    "attw:rqb": "attw --format table-flipped --pack ./packages/react-querybuilder",
    "attw:tremor": "attw --format table-flipped --pack ./packages/tremor",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "generate-examples": "bun ./examples/generateExamples.ts",
    "generate-parsers": "bun --bun run generate-sqlparser && bun --bun run generate-celparser && bun --bun generate-parsers-codemod",
    "generate-sqlparser": "bunx --bun ts-jison -n SQL -t typescript packages/core/src/utils/parseSQL/sql.jison --outfile packages/core/src/utils/parseSQL/sqlParser.ts",
    "generate-celparser": "bunx --bun ts-jison -n CEL -t typescript packages/core/src/utils/parseCEL/cel.jison --outfile packages/core/src/utils/parseCEL/celParser.ts",
    "generate-parsers-codemod": "sed -i 's/lexer = new \\(CEL\\|SQL\\)Lexer(/lexer: \\1Lexer = new \\1Lexer(/g' packages/core/src/utils/parse{CEL/cel,SQL/sql}Parser.ts",
    "generate-prisma-client": "./utils/gen-prisma-client.sh",
    "generate-shadcn-registry": "bun run --filter website generate-shadcn-registry",
    "update-mantine-css": "bun utils/update-mantine-css.ts",
    "outdated": "bun update --interactive --recursive",
    "reset-deps": "rm -rf node_modules packages/*/node_modules website/node_modules bun.lock bun.lockb && bun install --save-text-lockfile",
    "version": "bun version.ts && bun install && bun --bun run build && bun run generate-examples && git add examples packages website/package.json bun.lock",
    "web": "bun run --filter website start",
    "web:skiptypedoc": "RQB_TYPEDOC_DONE=true bun run --filter website start",
    "website:clearrun": "bun run --filter website clear && bun run --filter website start",
    "website:clearbuild": "bun run --filter website clear && bun run --filter website build",
    "website:build": "bun run generate-shadcn-registry && bun run --filter website build",
    "website:serve": "bun run --filter website serve",
    "website:deploy": "bun run --filter website deploy",
    "website:clear": "bun run --filter website clear"
  },
  "catalog": {
    "@reduxjs/toolkit": "^2.12.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.8.0",
