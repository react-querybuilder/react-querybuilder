{
  "name": "@react-querybuilder/graph",
  "description": "Graph query language support (Cypher, GQL, SPARQL, Gremlin) for React Query Builder",
  "version": "8.15.0",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/react-querybuilder_graph.legacy-esm.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/react-querybuilder_graph.d.mts",
        "default": "./dist/react-querybuilder_graph.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "types": "./dist/react-querybuilder_graph.legacy-esm.d.ts",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/react-querybuilder/react-querybuilder.git",
    "directory": "packages/graph"
  },
  "keywords": [
    "react",
    "querybuilder",
    "graph",
    "cypher",
    "gql",
    "sparql",
    "gremlin",
    "neo4j",
    "rdf"
  ],
  "scripts": {
    "start": "vite",
    "build": "bun --bun tsdown",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "devDependencies": {
    "@grafeo-db/js": "0.5.40",
    "@react-querybuilder/core": "8.15.0",
    "@testing-library/react": "catalog:test",
    "@testing-library/user-event": "catalog:test",
    "@types/react": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rollup-plugin-visualizer": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "@react-querybuilder/core": "8.15.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
