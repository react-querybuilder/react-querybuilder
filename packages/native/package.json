{
  "name": "@react-querybuilder/native",
  "description": "React Native components for react-querybuilder",
  "version": "8.14.4",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/react-querybuilder_native.legacy-esm.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/react-querybuilder_native.d.mts",
        "default": "./dist/react-querybuilder_native.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "types": "./dist/react-querybuilder_native.legacy-esm.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/react-querybuilder/react-querybuilder.git",
    "directory": "packages/native"
  },
  "license": "MIT",
  "homepage": "https://react-querybuilder.js.org/",
  "keywords": [
    "react",
    "querybuilder",
    "react-native",
    "native",
    "query",
    "builder",
    "operators",
    "component",
    "clause",
    "expression",
    "sql"
  ],
  "scripts": {
    "start": "vite",
    "build": "bun --bun tsdown",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "~0.85.1",
    "react-native-web": "~0.21.2",
    "react-querybuilder": "8.14.4",
    "react-redux": "catalog:",
    "react-test-renderer": "catalog:test",
    "rollup-plugin-visualizer": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:peer",
    "react-querybuilder": "8.14.4",
    "react-redux": "^9.1.0"
  }
}
