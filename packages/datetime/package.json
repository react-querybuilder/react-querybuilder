{
  "name": "@react-querybuilder/datetime",
  "description": "Date/time features for react-querybuilder",
  "version": "8.20.0",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/react-querybuilder_datetime.legacy-esm.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/react-querybuilder_datetime.d.mts",
        "default": "./dist/react-querybuilder_datetime.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./date-fns": {
      "import": {
        "types": "./dist/react-querybuilder_datetime.date-fns.d.mts",
        "default": "./dist/react-querybuilder_datetime.date-fns.mjs"
      },
      "require": {
        "types": "./dist/cjs/date-fns.d.ts",
        "default": "./dist/cjs/date-fns.js"
      }
    },
    "./dayjs": {
      "import": {
        "types": "./dist/react-querybuilder_datetime.dayjs.d.mts",
        "default": "./dist/react-querybuilder_datetime.dayjs.mjs"
      },
      "require": {
        "types": "./dist/cjs/dayjs.d.ts",
        "default": "./dist/cjs/dayjs.js"
      }
    },
    "./jsdate": {
      "import": {
        "types": "./dist/react-querybuilder_datetime.jsdate.d.mts",
        "default": "./dist/react-querybuilder_datetime.jsdate.mjs"
      },
      "require": {
        "types": "./dist/cjs/jsdate.d.ts",
        "default": "./dist/cjs/jsdate.js"
      }
    },
    "./luxon": {
      "import": {
        "types": "./dist/react-querybuilder_datetime.luxon.d.mts",
        "default": "./dist/react-querybuilder_datetime.luxon.mjs"
      },
      "require": {
        "types": "./dist/cjs/luxon.d.ts",
        "default": "./dist/cjs/luxon.js"
      }
    },
    "./dist/*": "./dist/*"
  },
  "types": "./dist/react-querybuilder_datetime.legacy-esm.d.ts",
  "files": [
    "dist",
    "dayjs",
    "date-fns",
    "jsdate",
    "luxon"
  ],
  "license": "MIT",
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/react-querybuilder/react-querybuilder.git",
    "directory": "packages/datetime"
  },
  "keywords": [
    "react",
    "querybuilder",
    "date",
    "time",
    "datetime",
    "datepicker"
  ],
  "scripts": {
    "start": "vite",
    "build": "bun run build:main && bun run build:css",
    "build:main": "bun --bun tsdown",
    "build:css": "mkdir -p dist/styles && cp src/*.scss dist && cp src/styles/*.scss dist/styles && bun sass --style=compressed dist:dist",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "devDependencies": {
    "@date-fns/tz": "^1.5.0",
    "@electric-sql/pglite": "catalog:test",
    "@grafeo-db/js": "^0.5.42",
    "@prisma/client": "^7.7.0",
    "@tanstack/db": "^0.6.8",
    "@testing-library/dom": "catalog:test",
    "@testing-library/react": "catalog:test",
    "@testing-library/user-event": "catalog:test",
    "@types/luxon": "catalog:",
    "@types/react": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "date-fns": "catalog:",
    "dayjs": "catalog:",
    "drizzle-orm": "^0.45.2",
    "json-logic-js": "catalog:",
    "jsonata": "catalog:",
    "luxon": "catalog:",
    "mongodb-memory-server-core": "catalog:test",
    "mongoose": "catalog:test",
    "pglite-prisma-adapter": "^0.7.2",
    "prisma": "^7.7.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-querybuilder": "8.20.0",
    "rollup-plugin-visualizer": "catalog:",
    "sass": "catalog:",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "date-fns": "catalog:peer",
    "dayjs": "catalog:peer",
    "luxon": "catalog:peer",
    "react": "catalog:peer",
    "react-querybuilder": "8.20.0"
  },
  "peerDependenciesMeta": {
    "date-fns": {
      "optional": true
    },
    "dayjs": {
      "optional": true
    },
    "luxon": {
      "optional": true
    }
  }
}
